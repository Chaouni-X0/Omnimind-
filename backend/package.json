{
  "name": "omnimind-backend",
  "version": "2.0.0",
  "description": "OmniMind Backend Server - Node.js + Express",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "express": "^4.22.1",
    "axios": "^1.13.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "octokit": "^4.1.0",
    "socket.io": "^4.8.1",

    "chokidar": "^3.6.0",
    "highlight.js": "^11.10.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.3",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.39.2",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.14"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
